{
  "name": "casilhero/brazilian-validators-laravel",
  "description": "Laravel bridge for casilhero/brazilian-validators.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "validation",
    "cpf",
    "cnpj",
    "brazil"
  ],
  "authors": [
    {
      "name": "Casilhero",
      "email": "opensource@casilhero.com"
    }
  ],
  "repositories": [
    {
      "type": "path",
      "url": "../brazilian-validators"
    }
  ],
  "require": {
    "php": "^8.1",
    "casilhero/brazilian-validators": "^1.0",
    "illuminate/contracts": "^12.0 || ^13.0",
    "illuminate/support": "^12.0 || ^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^10.0 || ^11.0",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Casilhero\\BrazilianValidatorsLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Casilhero\\BrazilianValidatorsLaravel\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "format:check": "vendor/bin/pint --test",
    "test": "vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Casilhero\\BrazilianValidatorsLaravel\\BrazilianValidatorsServiceProvider"
      ],
      "aliases": {
        "BrazilianValidator": "Casilhero\\BrazilianValidatorsLaravel\\Facades\\BrazilianValidator"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
